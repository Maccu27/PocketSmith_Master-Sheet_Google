# PocketSmith API
POCKETSMITH_API_KEY=your_pocketsmith_developer_key

# Google Service Account
# Either point to a JSON file path...
GOOGLE_SERVICE_ACCOUNT_FILE=/path/to/service-account.json
# ...or paste the entire JSON content as a single line (Railway-friendly).
# If both are set, GOOGLE_SERVICE_ACCOUNT_JSON wins.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Master sheet IDs per year
MASTER_SHEET_2026=1iHjASB2wmC0v3pbQtfv5vj5zugazm6uHna6u9WBV43I

# Optional: Drive folder where new yearly sheets get auto-created (Phase 1b/1c)
DRIVE_FINANZEN_FOLDER_ID=

# Verified label name in PocketSmith (case-sensitive)
VERIFIED_LABEL=Verifiziert

# Years to sync (comma-separated)
SYNC_YEARS=2026
